   "source": [
    "## wap to count a number of digits and alphabets present inside in entered string"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 7,
   "id": "9af4744a-bfc5-4ebc-bf70-6f98505db6c7",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a string with digits:  deepankar432\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Number of digits:  3\n",
      "Number of alphabets:  9\n"
     ]
    }
   ],
   "source": [
    "s = input('Enter a string with digits: ')\n",
    "a = 0\n",
    "d = 0\n",
    "for i in s:\n",
    "    if i.isdigit():\n",
    "        d+=1\n",
    "    elif i.isalpha():\n",
    "        a+=1\n",
    "print('Number of digits: ', d)\n",
    "print('Number of alphabets: ', a)"
   ]
  },
